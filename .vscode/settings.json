{
  "files.associations": {
    ".ToDo": "markdown",
    "*.yaml.tpl": "helm"
  },
  "todohighlight.toggleURI": true,
  "todohighlight.isCaseSensitive": false,
  "todohighlight.keywords": [
    {
      "text": "@ToDo",
      "color": "red",
      "backgroundColor": "black"
    },
    {
      "text": "@note",
      "color": "blue",
      "backgroundColor": "lightblue"
    }
  ],
  "todohighlight.exclude": [
    "**/node_modules/**",
    ".vscode"
  ],
  "workbench.colorTheme": "Tomorrow Night Blue",
  "material-icon-theme.files.associations": {
    ".projenrc.ts": "controller",
    "index.ts": "contributing",
    "*.enum.ts": "scheme",
    "*.function.ts": "fortran",
    "*.type.ts": "toml",
    "*.esc.ts": "key",
    "*.res.ts": "scheme",
    "*.data.ts": "scheme",
    "*.diagnosis.md": "document",
    "contract.ts": "bbx"
  },
  "material-icon-theme.folders.associations": {
    "crd": "kubernetes",
    "abstract": "class",
    ".kube": "kubernetes",
    "workstation": "home",
    ".projen": "project",
    ".diagnosis": "resource",
    "ventoy": "robot"
  },
  "//": "~~ Generated by projen. To modify, edit .projenrc.ts and run \"pnpm exec projen\"."
}
