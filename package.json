{
  "name": "ApexCaptain.IaC.Pulumi",
  "scripts": {
    "build": "projen build",
    "clobber": "projen clobber",
    "compile": "projen compile",
    "default": "projen default",
    "eject": "projen eject",
    "eslint": "projen eslint",
    "package": "projen package",
    "post-compile": "projen post-compile",
    "post-upgrade": "projen post-upgrade",
    "pre-compile": "projen pre-compile",
    "test": "projen test",
    "upgrade": "projen upgrade",
    "watch": "projen watch",
    "projen": "projen",
    "git:commit": "git commit -F .github/generated/commit-message.txt",
    "git:pr": "gh pr create --title \"$(cat .github/generated/pull-request-title.md)\" --body-file \".github/generated/pull-request-body.md\"",
    "build:workspaces": "turbo run build --filter \"./common/*\" --filter \"./infra/*\"",
    "build:infra": "turbo run build --filter \"./infra/*\"",
    "posteslint": "turbo run eslint --filter \"./common/*\" --filter \"./infra/*\" --concurrency=3",
    "script:mergeKubeConfig": "ts-node scripts/merge-kube-config.script.ts",
    "script:generateNovaDiagnosis": "ts-node scripts/generate-nova-diagnosis.script.ts",
    "script:fetchWorkstationKubeconfig": "ts-node scripts/fetch-workstation-kubeconfig.script.ts",
    "pulumi:preview": "turbo run pulumi:preview --filter \"./infra/*\"",
    "pulumi:up": "turbo run pulumi:up --filter \"./infra/*\" --ui=tui",
    "postpulumi:up": "pnpm script:mergeKubeConfig && pnpm script:generateNovaDiagnosis",
    "pulumi:install": "pulumi install --no-dependencies --cwd ./common/bridged-provider",
    "postprojen": "pnpm build",
    "postbuild": "turbo run build --filter \"./common/*\" --filter \"./infra/*\"",
    "postupgrade": "turbo run upgrade --filter \"./common/*\" --filter \"./infra/*\" --concurrency=1",
    "kubespray:cluster": "ANSIBLE_CONFIG=ansible/third_party/kubespray/ansible.cfg ansible-playbook -b -i ansible/workstation/inventory/inventory.ini ansible/third_party/kubespray/cluster.yml",
    "kubespray:upgradeCluster": "ANSIBLE_CONFIG=ansible/third_party/kubespray/ansible.cfg ansible-playbook -b -i ansible/workstation/inventory/inventory.ini ansible/third_party/kubespray/upgrade-cluster.yml",
    "ansible:preConfigure": "cd ansible/workstation\nansible-playbook pre-configure.yml",
    "ssh:workstation:0": "sshpass -P \"passphrase\" -p $WORKSTATION_BOOTSTRAP_SSH_PRIVATE_KEY_PASSPHRASE ssh -o StrictHostKeyChecking=accept-new -i \".keys/workstation.key\" -p \"$WORKSTATION_BOOTSTRAP_NODE_0_EXTERNAL_SSH_PORT\" $WORKSTATION_BOOTSTRAP_USERNAME@$WORKSTATION_DOMAIN_IPTIME"
  },
  "author": {
    "name": "ApexCaptain",
    "email": "ayteneve93@gmail.com",
    "organization": false
  },
  "devDependencies": {
    "@pulumi/esc-sdk": "^0.14.0",
    "@types/json2md": "^1.5.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.4",
    "@types/semver": "^7.7.1",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "constructs": "^10.0.0",
    "cron-time-generator": "^2.0.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "handlebars": "^4.7.9",
    "json2md": "^2.0.3",
    "lodash": "^4.18.1",
    "prettier": "^3.9.3",
    "projen": "^0.101.1",
    "sha512-crypt-ts": "^0.1.27",
    "ssh2": "^1.17.0",
    "timezone-enum": "^1.0.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@pulumi/pulumi": "^3.248.0",
    "axios": "^1.18.1",
    "chalk": "^4.1.2",
    "dedent": "^1.7.2",
    "flat": "^6.0.1",
    "flatley": "^5.2.0",
    "lodash": "^4.18.1",
    "semver": "^7.8.5",
    "yaml": "^2.9.0"
  },
  "pnpm": {},
  "main": "lib/index.js",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "types": "lib/index.d.ts",
