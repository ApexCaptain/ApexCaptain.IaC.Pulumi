{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "lib/**",
        "dist/**"
      ]
    },
    "compile": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "lib/**"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ]
    },
    "upgrade": {
      "cache": false
    },
    "pulumi:preview": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "cache": false,
      "passThroughEnv": [
        "PULUMI_*"
      ]
    },
    "pulumi:up": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "cache": false,
      "interactive": true,
      "passThroughEnv": [
        "PULUMI_*"
      ]
    }
  },
  "//": "~~ Generated by projen. To modify, edit .projenrc.ts and run \"pnpm exec projen\"."
}
